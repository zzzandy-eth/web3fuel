# Environment Variables Example
# Copy this to .env and fill in your actual values

# ============================================
# Flask Configuration
# ============================================
FLASK_SECRET_KEY=your-random-secret-key-here
FLASK_ENV=production
FLASK_DEBUG=False

# ============================================
# Database Configuration (MySQL Local)
# ============================================
DB_HOST=localhost
DB_NAME=web3fuel_reply_assistant
DB_USER=reply_assistant
DB_PASSWORD=your-database-password
DB_PORT=3306

# ============================================
# Discord OAuth (User Authentication)
# ============================================
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI=http://localhost:5000/tools/reply-assistant/auth/discord/callback

# ============================================
# Discord Bot (Notifications)
# ============================================
DISCORD_BOT_TOKEN=your-discord-bot-token

# ============================================
# X/Twitter API (Primary feed source)
# ============================================
# Get Bearer Token from: https://developer.twitter.com/en/portal/dashboard
# Free tier: 50 reads/day, Basic: $100/month (10K reads)
X_BEARER_TOKEN=your-x-bearer-token

# Optional: For posting (not currently used)
X_API_KEY=your-x-api-key
X_API_SECRET=your-x-api-secret
X_ACCESS_TOKEN=your-x-access-token
X_ACCESS_TOKEN_SECRET=your-x-access-token-secret
X_CLIENT_ID=your-x-client-id
X_CLIENT_SECRET=your-x-client-secret

# ============================================
# RapidAPI Twitter241 (Fallback when X API limit reached)
# ============================================
# Get API key from: https://rapidapi.com/davethebeast/api/twitter241
# Check your plan's request limits
RAPIDAPI_KEY=your-rapidapi-key
RAPIDAPI_DAILY_LIMIT=50  # Adjust based on your subscription

# ============================================
# Claude API (AI Reply Generation)
# ============================================
CLAUDE_API_KEY=your-claude-api-key

# Daily limits (cost control)
DAILY_AI_LIMIT=1000
AI_COST_LIMIT=5.0

# ============================================
# Reply Assistant Configuration
# ============================================
TOOL_PASSWORD=your-password-here
ADMIN_DISCORD_ID=your-discord-user-id
DISCORD_CHANNEL_ID=your-discord-channel-id

# ============================================
# Monitoring Settings
# ============================================
# Check interval - adjust based on number of accounts:
#   25 accounts × 4 checks/day = 100 API calls (uses X API + RapidAPI)
#   Recommended: 360 (6 hours) for active monitoring, 720 (12 hours) for conservative
CHECK_INTERVAL_MINUTES=360

# Max post age should be >= check interval to avoid missing posts
MAX_POST_AGE_HOURS=8

MAX_NITTER_RETRIES=5
MIN_QUALITY_SCORE=5
MAX_NOTIFICATIONS_PER_DAY=20

# ============================================
# Nitter Instances (Comma-separated)
# ============================================
NITTER_INSTANCES=nitter.net,nitter.poast.org,nitter.privacydev.net,nitter.cz,nitter.unixfox.eu

# ============================================
# RSS Bridge Instances (Comma-separated)
# ============================================
RSS_BRIDGE_INSTANCES=https://rss-bridge.org/bridge01/,https://wtf.roflcopter.fr/rss-bridge/,https://rssbridge.emeraldonion.org/
